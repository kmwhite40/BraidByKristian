# =============================================================================
# Braids by Kristian — environment
#
# THE SITE BUILDS AND RUNS WITH NONE OF THESE SET.
# Every variable below unlocks an optional integration. Unset, the dependent
# feature hides itself rather than showing a fake. Copy to `.env.local`:
#     cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# The production origin. Drives canonical URLs, the sitemap and OG image URLs.
# MUST be set before launch or canonicals will point at the placeholder domain.
NEXT_PUBLIC_SITE_URL=https://braidsbykristian.com


# -----------------------------------------------------------------------------
# Contact form  (docs/CONTACT.md)
# -----------------------------------------------------------------------------
# Unset: the form still validates and returns success, and the submission is
# logged server-side with a warning. Set all three to actually deliver mail.
#
# THIS REPOSITORY IS PUBLIC. Never fill the addresses in here — set them in the
# host's environment panel. A real address committed to a public repo is
# harvested by scrapers, which is the whole reason it is not on the site either.
#
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=
# Where enquiries land: Kristian's Google Workspace mailbox on this domain.
CONTACT_TO_EMAIL=
# The FROM address. Use the `send.` subdomain, NOT the root domain —
# e.g. site@send.braidsbykristian.com
#
# WHY: the root domain already publishes an SPF record for Google Workspace
# ("v=spf1 include:_spf.google.com ~all"). A domain may only have ONE SPF
# record; adding a second for Resend is a permerror that degrades delivery of
# BOTH. Verifying a subdomain in Resend gives it its own SPF/DKIM and leaves
# Kristian's mail untouched. See docs/CONTACT.md.
CONTACT_FROM_EMAIL=


# -----------------------------------------------------------------------------
# Analytics  (docs/ANALYTICS.md)
# -----------------------------------------------------------------------------
# One of: plausible | vercel | (empty = no analytics, no script loaded)
# Plausible is cookieless, which is why no consent banner ships. If you swap in
# a provider that sets cookies, you must add a consent gate first.
NEXT_PUBLIC_ANALYTICS_PROVIDER=
# Required when the provider is `plausible`.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=


# -----------------------------------------------------------------------------
# Acuity API  (docs/BOOKING.md)  — OPTIONAL, server-side only
# -----------------------------------------------------------------------------
# NOT required for booking. The scheduler embed works without any credentials.
# These only enable future server-side reads (e.g. a real "next opening"
# indicator). Never expose them with NEXT_PUBLIC_.
ACUITY_USER_ID=
ACUITY_API_KEY=


# -----------------------------------------------------------------------------
# Instagram  (docs/IMAGES.md)  — OPTIONAL, build-time only
# -----------------------------------------------------------------------------
# Instagram cannot be scraped: the profile is behind a login wall and its image
# URLs are session-signed. This token drives the OFFICIAL Graph API, used at
# build time to download photos into /public. Long-lived tokens expire after 60
# days and must be refreshed.
INSTAGRAM_ACCESS_TOKEN=
